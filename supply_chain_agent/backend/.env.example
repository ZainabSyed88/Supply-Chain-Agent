# Required for every environment. Set these in Railway before first deploy.
SECRET_KEY=replace-with-a-long-random-secret

# Required only when bootstrapping the very first admin in an empty database.
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_EMAIL=admin@yourcompany.com
ADMIN_BOOTSTRAP_PASSWORD=replace-with-a-strong-password
ADMIN_BOOTSTRAP_FULL_NAME=ChainPulse Admin

# Core app
DATABASE_URL=sqlite:///./chainpulse.db
FRONTEND_URL=http://localhost:8000

# Optional integrations
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
NEWS_API_KEY=
WEATHER_API_KEY=
SMTP_USER=
SMTP_PASSWORD=
